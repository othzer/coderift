// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted MongoDB database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  PREMIUM_USER
  ADMIN
}

model User{
  id String @id @default(cuid()) @map("_id")
  name String?
  email String @unique
  image String?
  accounts Account[]
  role UserRole @default(USER)

  myPlaygrounds Playground[]
  starmark Starmark[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @map("userId")
  type              String
  provider          String
  providerAccountId String
  refreshToken     String? @map("refresh_token")
  accessToken      String? @map("access_token")
  expiresAt        Int? @map("expires_at")
  tokenType        String? @map("token_type")
  scope             String?
  idToken          String? @map("id_token")
  sessionState     String? @map("session_state")
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@index([userId])
}

enum Templates {
  REACT
  NEXTJS
  EXPRESS
  VUE
  ANGULAR
  HONO
  CUSTOM
}

model Playground {
  id String @id @default(cuid()) @map("_id")
  title String
  description String?
  template Templates @default(REACT)

  // When true, the playground is viewable read-only via a shareable link
  // without signing in. Defaults to private.
  isPublic Boolean @default(false)

  userId String @map("userId")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  starmark Starmark[]
  templateFiles TemplateFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Starmark {
  id String @id @default(cuid()) @map("_id")
  userId String
  playgroundId String
  isMarked Boolean
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  playground Playground @relation(fields: [playgroundId], references: [id], onDelete: Cascade)

  @@unique([userId, playgroundId]) 
}

model TemplateFile{
  id String @id @default(cuid()) @map("_id")
  content Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playgroundId String @unique
  playground Playground @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id  String @id @default(cuid()) @map("_id")
  userId String
  playgroundId String?  // chat is scoped to the playground it was sent from
  role   String  // "user" or "assistant"
  content String
  attachments String[] @default([])  // paths of project files attached to this message
  createdAt DateTime  @default(now())

  user  User @relation(fields: [userId] , references: [id] , onDelete: Cascade)

  @@index([userId, playgroundId])
}