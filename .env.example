# ---- Database ----
# MongoDB connection string (e.g. from MongoDB Atlas). Used by Prisma.
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/rigpaz"

# ---- Site ----
# Public origin of the deployment. Used as the metadataBase for OG/Twitter tags.
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_APP_URL="https://rigpaz.vercel.app"

# ---- Auth.js (NextAuth v5) ----
# Generate one with: npx auth secret
AUTH_SECRET=

# GitHub OAuth app credentials (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth app credentials (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- AI features ----
# Inline code completion (Mistral Codestral). Free key at https://console.mistral.ai
MISTRAL_API_KEY=

# AI chat assistant (Groq, OpenAI-compatible). Free key at https://console.groq.com
GROQ_API_KEY=
